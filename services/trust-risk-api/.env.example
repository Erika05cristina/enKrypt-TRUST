# Thirdweb (facilitator) — ver dashboard thirdweb
THIRDWEB_SECRET_KEY=

# Smart Account ERC-4337 en Avalanche Fuji (Server Wallets en thirdweb)
THIRDWEB_SERVER_WALLET_ADDRESS=

# Wallet que recibe el USDC del pago x402
MERCHANT_WALLET_ADDRESS=

# URL publica exacta del API (debe coincidir con la que usa el cliente al firmar)
# Ejemplo local: http://127.0.0.1:8787
TRUST_PUBLIC_BASE_URL=http://127.0.0.1:8787

# Puerto del servidor local (opcional)
PORT=8787
# Escucha en todas las interfaces (default 0.0.0.0) para ngrok / red local. Para solo local: HOST=127.0.0.1
# HOST=0.0.0.0

# --- x402 precios (thirdweb Money string). Default barato para pruebas. ---
# TRUST_SETTLE_PRICE_USD=$0.001
# TRUST_SETTLE_DEEP_PRICE_USD=$0.02

# --- Ollama (opcional): resumen LLM tras pago + motor B3 ---
# TRUST_LLM_ENABLED=false
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# TRUST_LLM_MAX_OUTPUT_TOKENS_STANDARD=256
# TRUST_LLM_MAX_OUTPUT_TOKENS_DEEP=1024
# Defaults altos para evitar truncar calldata/Solidity/bytecode (sube si tu modelo aguanta mas contexto)
# TRUST_LLM_MAX_INPUT_CHARS=1000000
# TRUST_LLM_TIMEOUT_MS=45000
# Incluir bytecode en tier estandar (default: no)
# TRUST_LLM_INCLUDE_BYTECODE_STANDARD=false
# Si hay Solidity verificado del explorador, no mandar bytecode al LLM (default: si)
# TRUST_LLM_PREFER_SOURCE_OVER_BYTECODE=true
# Max caracteres hex bytecode en prompt (por tier)
# TRUST_LLM_BYTECODE_MAX_CHARS_STANDARD=1000000
# TRUST_LLM_BYTECODE_MAX_CHARS_DEEP=2000000
# Max caracteres de Solidity verificado en el prompt
# TRUST_LLM_SOLIDITY_MAX_CHARS=1000000

# --- RPC Fuji: eth_getCode para contractProbe + contexto LLM (opcional; sin URL el 200 sigue con B3) ---
# TRUST_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# TRUST_RPC_TIMEOUT_MS=5000

# --- Explorador Fuji (Routescan API compatible Etherscan): fuente verificada + flags B3 ---
# Por defecto se usa la URL publica de Routescan testnet 43113; opcional API key
# TRUST_EXPLORER_API_URL=https://api.routescan.io/v2/network/testnet/evm/43113/etherscan/api
# TRUST_EXPLORER_API_KEY=
# TRUST_EXPLORER_TIMEOUT_MS=12000
# TRUST_EXPLORER_DISABLED=false

# --- ERC-8004 (opcional): eco en JSON 200 + GET /agent-registration.json ---
# Tras mint en IdentityRegistry (Avalanche testnet / Fuji C-Chain 43113) y setAgentURI(agentId, <TRUST_PUBLIC_BASE_URL>/agent-registration.json):
# TRUST_ERC8004_CHAIN_ID=43113
# IdentityRegistry desplegado (lista oficial erc-8004 Avalanche Testnet):
# TRUST_ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
# TRUST_ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
# tokenId del agente (string):
# TRUST_ERC8004_AGENT_ID=0
# TRUST_ERC8004_AGENT_NAME=TRUST Risk Agent
# TRUST_ERC8004_AGENT_DESCRIPTION=Paid risk API with x402 on Fuji.

# --- B3: fixtures opcionales del motor de riesgo (Fuji, coma-separadas) ---
# TRUST_FIXTURE_TRUSTED_CONTRACTS=0xabc...,0xdef...
# TRUST_FIXTURE_MALICIOUS_CONTRACTS=0x...
# TRUST_FIXTURE_SUSPICIOUS_CONTRACTS=0x...
